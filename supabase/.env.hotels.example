## Example env for Hotels module (DO NOT commit real secrets)
# Set these in Supabase project secrets / Edge Function env instead of in repo.

HOTELBEDS_API_KEY=your_hotelbeds_api_key_here
HOTELBEDS_SECRET=your_hotelbeds_secret_here

# Optional: override mode if desired (test|live). If absent, DB travel_provider_settings.mode is used.
HOTELBEDS_MODE=test
