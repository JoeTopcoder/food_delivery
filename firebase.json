{
  "hosting": [
    {
      "target": "restaurant",
      "public": "build/web_restaurant",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|wasm)",
          "headers": [
            { "key": "Cache-Control", "value": "max-age=31536000" }
          ]
        },
        {
          "source": "flutter_service_worker.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "firebase-messaging-sw.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" },
            { "key": "Service-Worker-Allowed", "value": "/" }
          ]
        }
      ]
    },
    {
      "target": "admin",
      "public": "build/web_admin",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|wasm)",
          "headers": [
            { "key": "Cache-Control", "value": "max-age=31536000" }
          ]
        },
        {
          "source": "flutter_service_worker.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        }
      ]
    }
  ]
}
